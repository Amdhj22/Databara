# Copy to .env and fill in. Never commit .env.

# ── Strava ────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random secret used to verify webhook subscription registration.
STRAVA_VERIFY_TOKEN=
# Initial athlete refresh token; rotated automatically on each refresh.
STRAVA_REFRESH_TOKEN=

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Random secret echoed by Telegram in X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated chat IDs allowed to interact with the bot.
TELEGRAM_ALLOWED_CHAT_IDS=

# ── Anthropic Claude ──────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Server ────────────────────────────────────────────────
HTTP_ADDR=:8080
LOG_LEVEL=info
DB_PATH=./databara.db

# ── Public callback URL (for webhook registration) ────────
PUBLIC_BASE_URL=https://databara.example.com
